# Base URL of the AnythingLLM REST API (including /api/v1).
AnythingLLM_API_URL = "http://localhost:3001/api/v1"

# Bearer token used to authenticate with AnythingLLM.
AnythingLLM_API_Key = "YOUR-API-KEY-HERE"

# Optional API key for external callers.  When set, API endpoints require
# an "Authorization: Bearer <key>" header.  Leave empty to disable.
APP_API_KEY = ""
